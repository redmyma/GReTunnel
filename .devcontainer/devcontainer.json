{
  "name": "ghtun-warzone",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": false
    },
    "ghcr.io/devcontainers/features/github-cli:1": {
      "version": "latest"
    }
  },
  // این خط باعث می‌شود به محض ساخته شدن کانتینر، سرویس ران شود
  "onCreateCommand": "gh codespace ports visibility 443:public -c $CODESPACE_NAME && sudo /usr/local/bin/xray -c /etc/config.json &>/tmp/xray.log &",
  // این خط لیست کانفیگ‌ها را به محض ورود شما به ترمینال چاپ می‌کند
  "postAttachCommand": "/usr/local/bin/print-configs.sh",
  "portsAttributes": {
    "443": {
      "label": "xray-ws",
      "protocol": "https",
      "onAutoForward": "silent"
    }
  },
  "forwardPorts": [443],
  "hostRequirements": {
    "cpus": 2
  }
}
